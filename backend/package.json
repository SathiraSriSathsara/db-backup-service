{
  "name": "db-backup-platform-backend",
  "version": "1.0.0",
  "description": "Database Backup Management Platform - Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "backup",
    "database",
    "mysql",
    "postgresql",
    "mongodb"
  ],
  "author": "Database Backup Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.2",
    "mysql2": "^3.6.5",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.5",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "socket.io": "^4.7.2",
    "redis": "^4.6.12",
    "nodemailer": "^6.9.7",
    "express-validator": "^7.0.0",
    "crypto": "^1.0.1",
    "ssh2-sftp-client": "^9.1.0",
    "aws-sdk": "^2.1567.0",
    "minio": "^7.1.3",
    "compression": "^1.7.4",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "sequelize-cli": "^6.6.2"
  }
}
